{
  "name": "@toolstackhq/reqpilot",
  "version": "1.0.3",
  "description": "Lightweight local-first REST API client. Modern Postman alternative.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toolstackhq/reqpilot.git"
  },
  "homepage": "https://github.com/toolstackhq/reqpilot",
  "bugs": {
    "url": "https://github.com/toolstackhq/reqpilot/issues"
  },
  "type": "module",
  "bin": {
    "reqpilot": "./server.js"
  },
  "scripts": {
    "dev": "concurrently -k -n API,UI -c cyan,magenta \"REQPILOT_NO_OPEN=1 npm start\" \"vite\"",
    "dev:ui": "vite",
    "build": "vite build",
    "prepack": "npm run build",
    "scaffold:desktop-wrapper": "node scripts/scaffold-desktop-wrapper.mjs",
    "desktop:build": "node scripts/build-desktop-wrapper.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --host",
    "docs:screenshots": "CAPTURE_DOC_SCREENSHOTS=1 playwright test tests/e2e/docs-screenshots.spec.js --reporter=line",
    "start": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "mock-server": "node tests/mock-server/mock-api-server.js"
  },
  "files": [
    "server.js",
    "dist/**",
    "src/server/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "proxy-agent": "^6.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^9.2.1",
    "jsdom": "^24.1.1",
    "vite": "^5.4.10",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.8"
  }
}
